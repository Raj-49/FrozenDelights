# Database
# For local MongoDB: mongodb://localhost:27017/frozendelights
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/frozendelights
MONGO_URI=mongodb://localhost:27017/frozendelights

# JWT
JWT_SECRET=your-jwt-secret-key
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Email (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
EMAIL_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=FrozenDelights <your_email@gmail.com>

# Server
PORT=5000
